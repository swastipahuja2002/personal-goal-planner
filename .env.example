# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — never commit real keys.

# Required — your Supabase project (Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional — only needed if you re-enable the real AI coach / plan importer.
# In this public demo the AI routes are stubbed and need no key.
# OPENAI_API_KEY=sk-your-openai-key
